# ============================================================
# AgentForge — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed.
# NEVER commit .env to version control!

# Database — SQLite (Prisma)
DATABASE_URL="file:./db/custom.db"

# GLM API — z-ai-web-dev-sdk handles authentication automatically.
# No API key needed when using z-ai-web-dev-sdk.
# The SDK reads credentials from the environment automatically.

# WebSocket Service
WS_SERVICE_URL=http://localhost:3003
WS_SERVICE_PORT=3003

# Application
NEXT_PUBLIC_APP_NAME=AgentForge
NEXT_PUBLIC_APP_URL=http://localhost:3000
